{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "watchPatterns": [
      "src/**/*",
      "prisma/**/*",
      "package.json"
    ]
  },
  "deploy": {
    "startCommand": "node -r dotenv/config .next/standalone/server.js",
    "preDeployCommand": "npx prisma db push --skip-generate && npx tsx scripts/seed.ts",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
