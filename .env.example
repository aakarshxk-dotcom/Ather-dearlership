# Supabase PostgreSQL connection string
DATABASE_URL="postgresql://postgres:PASSWORD@db.your-project.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:PASSWORD@db.your-project.supabase.co:5432/postgres"

# JWT secret for admin authentication (change this!)
JWT_SECRET="your-random-secret-key-here"

# SMTP settings (optional - leave empty to skip emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Ather Energy Dealership <noreply@atherdealership.in>"
ADMIN_EMAIL="admin@atherdealership.in"

# Admin seed credentials (first-run only)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Admin"
