# Supabase Transaction Pooler connection string
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# JWT secret for admin authentication (change this!)
JWT_SECRET="your-random-secret-key-here"

# SMTP settings (optional - leave empty to skip emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Ather Energy Dealership <noreply@atherdealership.in>"
ADMIN_EMAIL="admin@atherdealership.in"

# Admin seed credentials (first-run only)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Admin"
